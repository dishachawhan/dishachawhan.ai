import numpy as np
import matplotlib.pyplot as plt
from sklearn.linear_model import LinearRegression

n = int(input("Enter number of data points: "))

data = [list(map(float, input("Enter hours and marks (space separated): ").split())) for _ in range(n)]

data = np.array(data)
X = data[:, 0].reshape(-1, 1)
y = data[:, 1]

model = LinearRegression()
model.fit(X, y)

new_hours = float(input("Enter study hours to predict marks: "))
pred = model.predict([[new_hours]])

print("\nSlope:", model.coef_[0])
print("Intercept:", model.intercept_)
print("Predicted Marks:", pred[0])

plt.scatter(X, y)
plt.plot(X, model.predict(X))
plt.xlabel("Study Hours")
plt.ylabel("Marks")
plt.title("Linear Regression")
plt.show()